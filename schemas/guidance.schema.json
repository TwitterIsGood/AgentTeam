{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://forgeflow.local/schemas/guidance.schema.json",
  "title": "Guidance",
  "type": "object",
  "required": [
    "guidance_id",
    "workitem_id",
    "stage",
    "assessment",
    "observations",
    "suggestions",
    "severity",
    "should_intervene",
    "created_at"
  ],
  "properties": {
    "guidance_id": { "type": "string", "minLength": 1 },
    "workitem_id": { "type": "string", "minLength": 1 },
    "stage": {
      "type": "string",
      "enum": ["Intake", "Roundtable", "Architecture", "Implement", "Test", "Review", "PR", "Release"]
    },
    "assessment": {
      "type": "string",
      "enum": ["OnTrack", "Drifting", "Stuck", "AtRisk"]
    },
    "observations": { "type": "array", "items": { "type": "string" } },
    "suggestions": { "type": "array", "items": { "type": "string" } },
    "severity": { "type": "string", "enum": ["Info", "Warning", "Critical"] },
    "should_intervene": { "type": "boolean" },
    "created_at": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": false
}
